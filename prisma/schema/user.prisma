model User {
  id           String       @id @default(uuid())
  name         String       @db.VarChar(255)
  email        String       @unique
  password     String
  phone        String?
  address      String?
  profilePhoto String?
  role         Role
  activeStatus ActiveStatus @default(ACTIVE)

  properties     Property[]
  rentalRequests RentalRequest[] @relation("TenantRentalRequests")
  payments       Payment[]
  reviews        Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
